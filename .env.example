# Copy this file to .env and fill in real values. Restart `expo start` after changes.
# WARNING: EXPO_PUBLIC_* vars are inlined into the client bundle and are NOT secret.
# For anything beyond a hackathon demo, proxy these calls through a backend.

EXPO_PUBLIC_ELEVENLABS_API_KEY=
EXPO_PUBLIC_GEMINI_API_KEY=

# Optional: pin a specific ElevenLabs voice. Run the "List voices" debug button
# to see available voice IDs on your account. Falls back to the first voice if unset.
# eleven_multilingual_v2 speaks every supported language with any voice.
EXPO_PUBLIC_ELEVENLABS_VOICE_ID=

# Backboard.io — used by MedicationScreen to call aaditya/Llama3-OpenBioLLM-70B.
# WARNING: Backboard's docs explicitly forbid client-side use of this key. For
# anything beyond a localhost demo, proxy these calls through a backend.
EXPO_PUBLIC_BACKBOARD_API_KEY=

# IMPORTANT: aaditya/Llama3-OpenBioLLM-70B is NOT in OpenRouter's catalog (verified
# May 2026). To find a working configuration, run the DebugScreen "List Backboard
# providers + models" button and look for biomedical models in the output. If none
# exist on your account, switch to a strong general-purpose model with medical-aware
# prompting (e.g. provider=openai, model=gpt-4o, or provider=anthropic,
# model=claude-sonnet-4-6) until OpenBioLLM is added.
EXPO_PUBLIC_BACKBOARD_PROVIDER=featherless
EXPO_PUBLIC_BACKBOARD_MODEL=aaditya/Llama3-OpenBioLLM-70B
